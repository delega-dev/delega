# Delega configuration
DELEGA_HOST=0.0.0.0
DELEGA_PORT=18890

# Database
DELEGA_DB_PATH=/app/data/delega.db
# Optional override: DELEGA_DATABASE_URL=sqlite:////app/data/delega.db

# Security (set to true for production / multi-agent deployments)
# DELEGA_REQUIRE_AUTH=false
# DELEGA_CORS_ORIGINS=https://delega.yourdomain.com,http://localhost:18890

