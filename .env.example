# Delega configuration
DELEGA_HOST=0.0.0.0
DELEGA_PORT=18890

# Database
DELEGA_DB_PATH=/app/data/delega.db
# Optional override: DELEGA_DATABASE_URL=sqlite:////app/data/delega.db

# Security
DELEGA_REQUIRE_AUTH=true
DELEGA_CORS_ORIGINS=http://localhost:18890,http://localhost:5173,http://127.0.0.1:18890
# Set to false only for local development where unauthenticated API access is intentional.
# DELEGA_REQUIRE_AUTH=false
